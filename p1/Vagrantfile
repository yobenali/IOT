Vagrant.configure("2") do |config|
  config.vm.box = "ubuntu/focal64"
  config.ssh.insert_key = false

  # Server Node (Controller Mode)
  config.vm.define "yobenaliS" do |server|
    server.vm.hostname = "yobenaliS"
    server.vm.network "private_network", ip: "192.168.56.110"

    server.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = "1"
      vb.name = "yobenaliS"
      vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
    end

    server.vm.provision "shell", inline: <<-SHELL
    exho "=== Installing K3s Server ==="
    curl -sfL https://get.k3s.io | sh -
    sleep 10
    chmod 644 /var/lib/rancher/k3s/server/node-token   
    
    # Install kubectl
    if ! command -v kubectl &> /dev/null; then
      echo "Installing kubectl..."
      curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"
      chmod +x kubectl
      sudo mv kubectl /usr/local/bin/
    fi
  
    echo "=== K3s Server Installation Complete ==="
    systemctl status k3s --no-pager
    SHELL
  end

  # Worker Node (Agent Mode) - Starts separately
  config.vm.define "yobenaliSW", autostart: false do |worker|
    worker.vm.hostname = "yobenaliSW"
    worker.vm.network "private_network", ip: "192.168.56.111"
    
    worker.vm.provider "virtualbox" do |vb|
      vb.memory = "1024"
      vb.cpus = "1"
      vb.name = "yobenaliSW"
      vb.customize ["modifyvm", :id, "--nested-hw-virt", "on"]
    end
    
    worker.vm.provision "shell", inline: <<-SHELL
      echo "=== Waiting for Server to be Ready ==="
      for i in {1..60}; do
        echo "Attempt $i: Checking server..."
        if curl -k -s https://192.168.56.110:6443 > /dev/null 2>&1; then
          echo "✓ Server is reachable!"
          break
        fi
        if [ $i -eq 60 ]; then
          echo "✗ ERROR: Server not reachable after 60 attempts"
          exit 1
        fi
        sleep 2
      done
      
      echo "=== Retrieving Token from Server ==="
      TOKEN=""
      
      # Try method 1: SSH with Vagrant's insecure key
      if [ -z "$TOKEN" ]; then
        TOKEN=$(ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -i /vagrant/.vagrant/machines/yobenaliS/virtualbox/private_key vagrant@192.168.56.110 "sudo cat /var/lib/rancher/k3s/server/node-token" 2>/dev/null) || true
      fi

      # Try method 2: Direct file access (if shared folder works)
      if [ -z "$TOKEN" ] && [ -f "/vagrant/token.txt" ]; then
        TOKEN=$(cat /vagrant/token.txt)
      fi
      
      if [ -z "$TOKEN" ]; then
        echo "✗ ERROR: Could not retrieve token"
        echo "Manual installation required"
        exit 1
      fi
      
      echo "✓ Token retrieved successfully"
      
      echo "=== Installing K3s Agent ==="
      curl -sfL https://get.k3s.io | K3S_URL=https://192.168.56.110:6443 K3S_TOKEN=${TOKEN} sh -
      
      echo "=== K3s Agent Installation Complete ==="
      systemctl status k3s-agent --no-pager
    SHELL
  end
end
